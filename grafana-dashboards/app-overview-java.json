        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_committed_bytes{namespace=\"$namespace\", area=\"nonheap\"}) by (pod)", "legendFormat": "{{pod}} committed", "refId": "B" }
