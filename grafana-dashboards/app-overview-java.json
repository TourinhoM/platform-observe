      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(jvm_gc_pause_seconds_sum{namespace=\"$namespace\"}[5m])", "legendFormat": "{{pod}} {{gc}}", "refId": "A" }
      ],
      "title": "GC — tempo de pausa (taxa, por pod)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
