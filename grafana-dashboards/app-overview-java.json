        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_threads_daemon_threads{namespace=\"$namespace\"}", "legendFormat": "{{pod}} daemon", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_threads_peak_threads{namespace=\"$namespace\"}", "legendFormat": "{{pod}} peak", "refId": "C" }
      ],
      "title": "Threads JVM (por pod)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
