      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_cpu_usage{namespace=\"$namespace\"}", "legendFormat": "{{pod}} processo", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_cpu_usage{namespace=\"$namespace\"}", "legendFormat": "{{pod}} sistema", "refId": "B" }
      ],
      "title": "CPU (uso, por pod)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
