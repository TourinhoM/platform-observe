          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "disk_free_bytes{namespace=\"$namespace\"} / disk_total_bytes{namespace=\"$namespace\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
