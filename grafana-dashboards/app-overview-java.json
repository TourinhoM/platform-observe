      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"$namespace\"}[5m])) by (uri, status)", "legendFormat": "{{uri}} [{{status}}]", "refId": "A" }
      ],
      "title": "Taxa de requests HTTP (por rota/status)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_sum{namespace=\"$namespace\"}[5m])) by (uri) / sum(rate(http_server_requests_seconds_count{namespace=\"$namespace\"}[5m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "title": "Latência média HTTP (por rota)",
      "description": "Média, não percentil — Actuator só expõe summary (count/sum/max) por padrão, sem histogram_quantile disponível. Habilitar management.metrics.distribution.percentiles-histogram.http.server.requests=true pra ter p50/p95.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
