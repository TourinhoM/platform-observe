      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_used_bytes{namespace=\"$namespace\", area=\"heap\"}) by (pod)", "legendFormat": "{{pod}} used", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_committed_bytes{namespace=\"$namespace\", area=\"heap\"}) by (pod)", "legendFormat": "{{pod}} committed", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_max_bytes{namespace=\"$namespace\", area=\"heap\"}) by (pod)", "legendFormat": "{{pod}} max", "refId": "C" }
